      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0473081726705665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if SUM(sales)= 0 THEN 0&#13;&#10; ELSE sum([profit])/SUM([sales])&#13;&#10;END' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0473081727320066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales]-[profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0473081727418371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])/&#13;&#10;COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0473081727733764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [return_flag] = 1 THEN&#13;&#10;    1&#13;&#10;ELSE&#13;&#10;    0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay' datatype='string' name='[Calculation_0473081730646021]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days]&lt;=2 THEN &quot;Fast&quot;&#13;&#10;&#13;&#10;ELSEIF [delivery_days]&lt;=5 THEN &quot;Normal&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Delayed&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='High Discount' datatype='string' name='[Calculation_0473081730867206]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount]&gt;=0.3&#13;&#10;&#13;&#10;THEN &quot;High Discount&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Low Discount&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0473081732042759]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days]&lt;=2 THEN &quot;Fast&quot;&#13;&#10;&#13;&#10;ELSEIF [delivery_days]&lt;=5 THEN &quot;Normal&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Delayed&quot;&#13;&#10;&#13;&#10;END' />
      </column>
